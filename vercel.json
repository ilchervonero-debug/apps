{
  "buildCommand": "echo 'Static site with integrated apps'",
  "outputDirectory": "chervo-web",
  "rewrites": [
    {
      "source": "/ilframe/:path*",
      "destination": "/ilframe/dist/:path*"
    },
    {
      "source": "/ilframe",
      "destination": "/ilframe/dist/index.html"
    },
    {
      "source": "/ilframe/",
      "destination": "/ilframe/dist/index.html"
    }
  ]
}
